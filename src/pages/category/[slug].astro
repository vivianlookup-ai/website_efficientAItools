---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { categories, getToolsByCategory } from '@/lib/tools';

export const prerender = true;

export function getStaticPaths() {
  return Object.values(categories).map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const catTools = getToolsByCategory(category.slug);
---

<BaseLayout
  title={`${category.name} — Free Online Tools`}
  description={category.description}
>
  <div class="container">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/tools/">Tools</a>
        <span class="breadcrumb-sep">/</span>
        <span>{category.name}</span>
      </div>
      <span style="font-size: 3rem; margin-bottom: 12px; display: block;">{category.icon}</span>
      <h1>{category.name}</h1>
      <p>{category.description}</p>
    </div>
  </div>

  <div class="container">
    <div class="tool-gallery">
      {catTools.map((tool) => (
        <a href={tool.url} class="tool-card">
          <div class="tool-card-header">
            <div class="tool-card-icon" style={`background: ${tool.iconBg};`}>
              {tool.icon}
            </div>
            <div class="tool-card-info">
              <div class="tool-card-title">
                {tool.name}
                {tool.badge && (
                  <span class={`tool-card-badge badge-${tool.badge}`}>
                    {tool.badge === 'free' ? 'Free' : tool.badge === 'new' ? 'New' : 'Premium'}
                  </span>
                )}
              </div>
            </div>
          </div>
          <div class="tool-card-desc">{tool.tagline}</div>
          <div class="tool-card-footer">
            <div class="tool-card-tags">
              {tool.tags.slice(0, 3).map((tag) => (
                <span class="tool-tag">{tag}</span>
              ))}
            </div>
            <div class="tool-card-stats">
              <span>⚡ {tool.uses.toLocaleString()}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

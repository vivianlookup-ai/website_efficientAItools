---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the ToolCraft team. Report bugs, suggest tools, or ask questions."
>
  <div class="container">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>Contact</span>
      </div>
      <h1>Contact Us</h1>
      <p>Have an idea, found a bug, or just want to say hi? We'd love to hear from you.</p>
    </div>
  </div>

  <div class="container">
    <div class="page-content">
      <form style="display: flex; flex-direction: column; gap: 16px; max-width: 500px;">
        <div>
          <label style="display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 6px; color: var(--text-primary);">Name</label>
          <input type="text" placeholder="Your name" style="width: 100%; padding: 12px 16px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary); font-family: 'Inter', sans-serif; font-size: 0.9375rem; outline: none;" />
        </div>
        <div>
          <label style="display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 6px; color: var(--text-primary);">Email</label>
          <input type="email" placeholder="you@example.com" style="width: 100%; padding: 12px 16px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary); font-family: 'Inter', sans-serif; font-size: 0.9375rem; outline: none;" />
        </div>
        <div>
          <label style="display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 6px; color: var(--text-primary);">Message</label>
          <textarea rows="6" placeholder="Tell us what's on your mind..." style="width: 100%; padding: 12px 16px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary); font-family: 'Inter', sans-serif; font-size: 0.9375rem; outline: none; resize: vertical;"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Send Message</button>
        <p style="font-size: 0.8125rem; color: var(--text-tertiary);">This form is a placeholder — replace the action URL with your form service.</p>
      </form>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getGrade } from '@/lib/grades';

export const prerender = true;

export async function getStaticPaths() {
  const { grades } = await import('@/lib/grades');
  return grades.map((g) => ({
    params: { grade: g.id },
    props: { grade: g },
  }));
}

const { grade } = Astro.props;
const { grades: allGrades } = await import('@/lib/grades');
const gradeColors: Record<string, string> = {};
allGrades.forEach((g) => { gradeColors[g.id] = g.color; });
---

<BaseLayout title={`${grade.name} Math Worksheets`} description={grade.seoDescription}>
  <!-- Breadcrumb -->
  <div class="container" style="padding-top: 20px;">
    <nav style="font-size: 0.8125rem; color: var(--text-tertiary); display: flex; gap: 8px; align-items: center;">
      <a href="/" style="color: var(--text-tertiary);">Home</a>
      <span>/</span>
      <span style="color: var(--text-secondary);">{grade.name}</span>
    </nav>
  </div>

  <!-- Grade Header -->
  <section class="section" style="padding: 40px 0 20px;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 12px;">
        <div class="grade-badge" style={`background: ${grade.color}; width: 48px; height: 48px; font-size: 1.2rem;`}>{grade.label}</div>
        <div>
          <h1 style="font-size: 2rem; font-weight: 800; letter-spacing: -0.02em;">{grade.seoH1}</h1>
          <p style="font-size: 1rem; color: var(--text-secondary); margin-top: 4px;">{grade.description}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grade Navigation (sibling grades) -->
  <div class="container" style="margin-bottom: 20px;">
    <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
      <span style="font-size: 0.8125rem; font-weight: 600; color: var(--text-tertiary);">Jump to:</span>
      {allGrades.map((g) => (
        <a
          href={`/grade/${g.id}/`}
          class="btn btn-sm"
          style={`${g.id === grade.id
            ? `background: ${grade.color}; color: white; border: none;`
            : 'background: var(--bg-secondary); color: var(--text-secondary); border: 1px solid var(--border);'
          }`}
        >{g.label === 'K' ? 'K' : `G${g.label}`}</a>
      ))}
    </div>
  </div>

  <!-- Topics Grid -->
  <section class="section" style="padding: 20px 0 60px;">
    <div class="container">
      <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 24px;">{grade.name} Math Topics</h2>
      <div class="topic-grid">
        {grade.topics.map((topic) => (
          <a href={`/grade/${grade.id}/${topic.id}/`} class="topic-card" style="flex-direction: column; align-items: flex-start; gap: 8px; padding: 20px;">
            <div style="display: flex; align-items: center; gap: 12px; width: 100%;">
              <div class="topic-icon" style={`background: ${topic.bgColor};`}>{topic.icon}</div>
              <div class="topic-info">
                <h4>{topic.name}</h4>
                <span>{topic.worksheetCount} worksheets</span>
              </div>
            </div>
            <p style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.5;">{topic.description}</p>
            <div style="display: flex; gap: 8px; margin-top: 4px;">
              <span class={`difficulty difficulty-${topic.difficulty.toLowerCase()}`}>
                {topic.difficulty === 'Easy' ? '🟢 ' : topic.difficulty === 'Medium' ? '🟡 ' : '🔴 '}
                {topic.difficulty}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Grades -->
  <section class="section" style="padding: 40px 0; background: var(--bg-secondary);">
    <div class="container">
      <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 20px; text-align: center;">Other Grade Levels</h2>
      <div class="grade-grid" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));">
        {allGrades.filter((g) => g.id !== grade.id).map((g) => (
          <a href={`/grade/${g.id}/`} class="grade-card" style="padding: 16px;">
            <div class="grade-card-header" style="margin-bottom: 0;">
              <div class="grade-badge" style={`background: ${g.color}; width: 32px; height: 32px; font-size: 0.85rem;`}>{g.label}</div>
              <h3 style="font-size: 0.9375rem;">{g.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

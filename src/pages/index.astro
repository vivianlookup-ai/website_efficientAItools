---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tools, categories, getFeatured } from '@/lib/tools';

const featured = getFeatured();
const categoryEntries = Object.values(categories);
const recentTools = tools.slice().reverse().slice(0, 6);
---

<BaseLayout
  title="Free Online Tools — PDF, Documents, Downloads &amp; More"
  description="efficientAItools.com offers a curated collection of free online tools: PDF merger, Word converter, YouTube downloader, TikTok downloader, image compressor, and more. All free, no sign-up."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>
        Discover <span class="gradient">Free Online Tools</span><br />
        That Actually Work
      </h1>
      <p>
        PDF utilities, document converters, download tools, and more — all free, no sign-up required.
        Every tool runs right in your browser.
      </p>
      <div class="hero-search">
        <span class="search-icon">🔍</span>
        <input type="search" placeholder="Search tools by name or keyword..." />
      </div>
      <div class="hero-tags">
        <a href="/tool/pdf-merger/" class="hero-tag">📄 PDF Merger</a>
        <a href="/tool/word-to-pdf/" class="hero-tag">📝 Word to PDF</a>
        <a href="/tool/youtube-downloader/" class="hero-tag">🎬 YouTube Downloader</a>
        <a href="/tool/image-compressor/" class="hero-tag">📦 Image Compressor</a>
        <a href="/tool/json-formatter/" class="hero-tag">{'{ }'} JSON Formatter</a>
        <a href="/tool/math-worksheets/" class="hero-tag">🧮 Math Worksheets</a>
      </div>
      <div class="stats-bar">
        <div class="stat-item">
          <div class="stat-value">{tools.length}</div>
          <div class="stat-label">Free Tools</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{tools.reduce((s, t) => s + t.uses, 0).toLocaleString()}+</div>
          <div class="stat-label">Total Uses</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{Object.keys(categories).length}</div>
          <div class="stat-label">Categories</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">{tools.filter(t => t.price === 'free').length}</div>
          <div class="stat-label">Completely Free</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Browse by Category</h2>
        <p>Find the right tool for the job — organized by what they do.</p>
      </div>
      <div class="category-grid">
        {categoryEntries.map((cat) => {
          const count = tools.filter((t) => t.category === cat.slug).length;
          return (
            <a href={`/category/${cat.slug}/`} class="category-card">
              <div class="category-icon">{cat.icon}</div>
              <div class="category-name">{cat.name}</div>
              <div class="category-count">{count} tools</div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="section" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header">
        <h2>Featured Tools</h2>
        <p>Our most popular and powerful tools — hand-picked for you.</p>
      </div>
      <div class="tool-gallery">
        {featured.map((tool) => (
          <a href={tool.url} class="tool-card featured">
            <div class="tool-card-header">
              <div class="tool-card-icon" style={`background: ${tool.iconBg};`}>
                {tool.icon}
              </div>
              <div class="tool-card-info">
                <div class="tool-card-title">
                  {tool.name}
                  {tool.badge && (
                    <span class={`tool-card-badge badge-${tool.badge}`}>
                      {tool.badge === 'free' ? 'Free' : tool.badge === 'new' ? 'New' : 'Premium'}
                    </span>
                  )}
                </div>
              </div>
            </div>
            <div class="tool-card-desc">{tool.tagline}</div>
            <div class="tool-card-footer">
              <div class="tool-card-tags">
                {tool.tags.slice(0, 3).map((tag) => (
                  <span class="tool-tag">{tag}</span>
                ))}
              </div>
              <div class="tool-card-stats">
                <span>⚡ {tool.uses.toLocaleString()} uses</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- All Tools Gallery -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>All Tools</h2>
        <p>Every tool in our collection, at a glance.</p>
      </div>
      <div class="tool-gallery">
        {tools.map((tool) => (
          <a href={tool.url} class="tool-card">
            <div class="tool-card-header">
              <div class="tool-card-icon" style={`background: ${tool.iconBg};`}>
                {tool.icon}
              </div>
              <div class="tool-card-info">
                <div class="tool-card-title">
                  {tool.name}
                  {tool.badge && (
                    <span class={`tool-card-badge badge-${tool.badge}`}>
                      {tool.badge === 'free' ? 'Free' : tool.badge === 'new' ? 'New' : 'Premium'}
                    </span>
                  )}
                </div>
              </div>
            </div>
            <div class="tool-card-desc">{tool.tagline}</div>
            <div class="tool-card-footer">
              <div class="tool-card-tags">
                {tool.tags.slice(0, 3).map((tag) => (
                  <span class="tool-tag">{tag}</span>
                ))}
              </div>
              <div class="tool-card-stats">
                <span>⚡ {tool.uses.toLocaleString()}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding: 40px 0;">
    <div class="container">
      <div class="cta-section">
        <h2>Have a Tool Idea?</h2>
        <p>We're always building new tools. If there's something you need, let us know and we might build it.</p>
        <a href="/contact/" class="btn btn-primary">Suggest a Tool</a>
      </div>
    </div>
  </section>
</BaseLayout>

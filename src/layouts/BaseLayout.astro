---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const url = canonical || Astro.url.pathname;
const image = ogImage || 'https://efficientAItools.com/logo.png';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/tools/', label: 'All Tools' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];

// Logo height for layout
const LOGO_HEIGHT = 32;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | ToolCraft</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://efficientAItools.com${url}`} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | ToolCraft`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://efficientAItools.com${url}`} />
    <meta property="og:site_name" content="ToolCraft" />
    <meta property="og:image" content={image} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ToolCraft`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "ToolCraft",
      "url": "https://efficientAItools.com",
      "description": description,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://efficientAItools.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }, null)} />
    </script>
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href="/" class="logo">
          <img src="/logo.png" alt="ToolCraft" style="height: {LOGO_HEIGHT}px; width: auto;" />
          ToolCraft
        </a>
        <nav class="nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={url === item.href ? 'active' : ''}
            >
              {item.label}
            </a>
          ))}
          <a href="/tools/" class="nav-cta">Browse Tools</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="logo" style="margin-bottom: 12px;">
              <img src="/logo.png" alt="ToolCraft" style="height: 28px; width: auto;" />
              ToolCraft
            </a>
            <p>
              A curated collection of free online tools — PDF utilities, document converters, 
              download helpers, and more. Built for productivity, crafted for simplicity.
            </p>
          </div>
          <div class="footer-col">
            <h4>Tools</h4>
            <a href="/tools/">All Tools</a>
            <a href="/category/pdf/">PDF Tools</a>
            <a href="/category/word/">Word Documents</a>
            <a href="/category/download/">Download Tools</a>
            <a href="/category/converter/">Converters</a>
          </div>
          <div class="footer-col">
            <h4>Resources</h4>
            <a href="/blog/">Blog</a>
            <a href="/about/">About</a>
            <a href="/contact/">Contact</a>
            <a href="/worksheets/">Math Worksheets</a>
          </div>
          <div class="footer-col">
            <h4>Legal</h4>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Use</a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; {new Date().getFullYear()} ToolCraft. All rights reserved.</span>
          <span>Built with care</span>
        </div>
      </div>
    </footer>
  </body>
</html>
